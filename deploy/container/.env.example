# Local-only container deployment settings.
# Copy to .env next to compose.yml and edit.

DEV_WORKSPACE=/srv/dev/workspace

CODEX_WEB_PORT=8214
CODEX_WEB_MAX_UPLOAD_BYTES=26214400
CODEX_BUFFER_SIZE=104857600

# Used by compose.ghcr.yml.
GHCR_OWNER=pintjesb
IMAGE_TAG=latest

OPENCODE_WEB_PORT=4096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=replace-with-a-long-random-password

# Provider keys. Fill only what you use.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
