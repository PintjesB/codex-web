# Copy to /srv/dev/secrets/codex-web.env and chmod 600.
# Used by deploy/systemd/codex-web.service.

CODEX_WEB_WORKSPACE_ROOT=/srv/dev/workspace
CODEX_WEB_MAX_UPLOAD_BYTES=26214400
CODEX_BUFFER_SIZE=104857600

# codex-web should stay bound to localhost behind Traefik/Authelia.
# Do not set this unless you intentionally bind codex-web to a non-loopback address.
# CODEX_WEB_ALLOW_NON_LOOPBACK=1
